# User Management Service - ローカル開発環境設定

# =================================
# 認証機能フィーチャーフラグ
# =================================
# true: 認証機能有効（本番相当）
# false: 認証機能無効（開発用）
SKISHOP_AUTH_ENABLE=false

# =================================
# Spring Profile
# =================================
SPRING_PROFILES_ACTIVE=local

# =================================
# データベース設定
# =================================
POSTGRES_DB=skishop_user
POSTGRES_USER=skishop_user
POSTGRES_PASSWORD=password
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/skishop_user
SPRING_DATASOURCE_USERNAME=skishop_user
SPRING_DATASOURCE_PASSWORD=password

# =================================
# Redis設定
# =================================
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# =================================
# JVM設定
# =================================
JAVA_OPTS=-Xmx512m -Xms256m -Djava.security.egd=file:/dev/./urandom

# =================================
# pgAdmin設定（オプション）
# =================================
PGADMIN_DEFAULT_EMAIL=admin@skishop.com
PGADMIN_DEFAULT_PASSWORD=admin

# =================================
# アプリケーション設定
# =================================
# フロントエンドベースURL
FRONTEND_BASE_URL=http://localhost:3000

# メール設定（ローカルでは無効）
EMAIL_FROM=noreply@skishop.com
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# =================================
# 開発用設定
# =================================
# ログレベル
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SKISHOP_USER=DEBUG

# JPA設定
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop
